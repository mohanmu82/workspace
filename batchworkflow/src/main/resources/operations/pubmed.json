  {
    "name": "pubmed",
      "properties": {
        "attributes": {	
          "operationName": "ICE",
          "operationDescription": "Published data from pubmed"
        }
  		},    
      "mandatoryProperties": [
        { "property": "inputFilePath", "dataType": "string", "defaultValue": "${DATADIR}/pubmed.txt" }
        ,{ "property": "inputSource", "dataType": "string", "defaultValue": "FILE" }
      ],
      "activity": [
      {
        "name": "httpgetpubmeddata",
        "properties": {
          "application": "ICE",
          "dataEnvironment": "PRD"
        },	        
        "type": "HTTP",
        "http": {
          "url": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi?db=pubmed&id=${ID}&retmode=xml",
          "method": "GET",
          "threadCount": 5,
          "timeoutMs": 3000,
          "cache": {
            "name": "pubmeddata"
            ,"key" : "pubmed${ID}"
          }          
        }
      },
      {
        "name": "extractxmlpubmed",
        "type": "dataextraction",
        "dataExtraction": {
          "type": "XPATH",
          "threadCount": 20,
          "config": "classpath:xpaths/pubmed_xpaths.json"
        }
      }
    ],
    "enricher": {
      "type": "pre",
      "enhancer": "classpath:enricher/id_enricher.json"
    },
    "alias": [
      {
        "name": "TECHTOP10WITHFILTER",
        "mandatoryProperties": [
        ],
        "request": {
          "inputSource": "FILE",
          "inputFilePath": "${DATADIR}/pubmed.txt",
          "inputCount": 10,
          "filterInput": [
            { "column": "ID", "value": "11748935", "operation": "eq" }
          ]
        }
      },
      {
        "name": "ASYNC_ALL",
        "mandatoryProperties": [
        ],
        "request": {
          "inputSource": "FILE",
          "inputFilePath": "${DATADIR}/pubmed2.txt",
          "executionMode": "ASYNC",
          "httpThreadCount": 10,
          "httpTimeoutMs": 5000
        }
      }
    ]
  }