{
  "dataset": [
    {
      "name": "FXRATES.${DATESTAMP}",
      "key": "currency",
      "dataSource": {
        "inputSource": "FILE",
        "inputFilePath": "C:/work/data/fxRates_${DATESTAMP}.txt",
        "cache": {
          "name": "FXRATES",
          "key": "FXRATES.${DATESTAMP}"
        }
      }
    },
    {
      "name": "traderList",
      "key": "employeeid",
      "dataSource": {
        "inputSource": "HTTPCONFIG",
        "inputHttpUrl": "http://internal-api/traders"
      }
    }
  ],
  "data": [
    {
      "name": "ArticleSummary",
      "type": "replace",
      "value": "${ArticleTitle} (${PubYear})",
      "onError": ""
    },
    {
      "name": "fxRateDataset",
      "type": "replace",
      "value": "FXRATES.${DATESTAMP}",
      "onError": ""
    },
    {
      "name": "convertedAmount",
      "type": "lookup",
      "key": "${currency}",
      "dataset": "${fxRateDataset}",
      "attribute": "rate",
      "onError": "0"
    }
  ]
}
