  {
    "name": "pubmed",
    "activity": [
      {
        "name": "httpgetpubmeddata",
        "properties": {
          "application": "ICE",
          "dataEnvironment": "PRD"
        },	        
        "type": "HTTP",
        "http": {
          "url": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi?db=pubmed&id=${ID}&retmode=xml",
          "method": "GET",
          "threadCount": 5,
          "timeoutMs": 3000,
          "cache": {
            "name": "pubmeddata"
            ,"key" : "pubmed${ID}"
          }          
        }
      },
      {
        "name": "extractxmlpubmed",
        "type": "dataextraction",
        "dataExtraction": {
          "type": "XPATH",
          "threadCount": 10,
          "config": "classpath:xpaths/pubmed_xpaths.json"
        }
      }
    ],
    "enricher": {
      "type": "pre",
      "enhancer": "classpath:enricher/id_enricher.json"
    },
    "alias": [
      {
        "name": "TECH",
        "request": {
          "inputSource": "FILE",
          "inputFilePath": "C:/work/data/pubmed.txt",
          "inputCount": 10,
          "filterInput": [
            { "column": "ID", "value": "11748935", "operation": "eq" }
          ]
        }
      },
      {
        "name": "ASYNC_ALL",
        "request": {
          "inputSource": "FILE",
          "inputFilePath": "C:/work/data/pubmed.txt",
          "executionMode": "ASYNC",
          "httpThreadCount": 10,
          "httpTimeoutMs": 5000
        }
      }
    ],
    "responseProcessor": [
      {
        "name": "attribute12",
        "responseProcessor": {
          "type": "attribute",
          "name": "attribute12"
        }
      },
      {
        "name": "status",
        "responseProcessor": {
          "type": "aggregation",
          "name": "status"
        }
      }
    ]	    
  }