{
  "name": "my-operation",

  "mandatoryAttributes": "id,accountId",

  "properties": {
    "attributes": {
      "env": "PRD",
      "region": "US"
    },
    "file": {
      "path": "C:/work/config/operation.properties"
    },
    "http": {
      "url": "http://config.example.com/properties",
      "method": "GET",
      "timeoutMs": 3000
    }
  },

  "inputSource": {
    "type": "FILE",
    "httpConfig": {
      "url": "http://api.example.com/input-ids",
      "method": "GET",
      "jsonataTransform": "data.items.{ 'id': id, 'accountId': accountId }"
    }
  },

  "outputData": {
    "type": "HTTP",
    "outputFilePath": "C:/work/output/results.psv"
  },

  "auth": {
    "method": "NONE",
    "basic": {
      "username": "user",
      "password": "secret"
    },
    "jwt": {
      "url": "http://auth.example.com/token",
      "applicationName": "MyApp",
      "username": "svc-user",
      "password": "svc-pass"
    },
    "kerberos": {
      "username": "svc-user@REALM.COM",
      "keytab": "C:/keytabs/svc-user.keytab",
      "servicePrincipal": "HTTP/api.example.com@REALM.COM"
    },
    "digest": {
      "url": "http://auth.example.com/digest-token",
      "username": "svc-user",
      "password": "svc-pass"
    }
  },

  "columnTemplate": {
    "source": "classpath:columns.json"
  },

  "activity": [
    {
      "name": "fetch-data-get",
      "type": "HTTP",
      "properties": {
        "app": "MyApp"
      },
      "http": {
        "url": "http://api.example.com/items/{id}?env={env}",
        "method": "GET",
        "threadCount": 10,
        "timeoutMs": 5000,
        "header": {
          "Accept": "application/json",
          "X-Api-Key": "abc123",
          "X-Correlation-Id": "batch-runner"
        },
        "cache": {
          "name": "item-cache",
          "key": "item-{id}"
        }
      }
    },
    {
      "name": "fetch-data-post",
      "type": "HTTP",
      "http": {
        "url": "http://api.example.com/items/search",
        "method": "POST",
        "contentType": "application/json",
        "bodyTemplate": "{\"id\": \"{id}\", \"account\": \"{accountId}\"}",
        "threadCount": 5,
        "timeoutMs": 8000,
        "header": {
          "Accept": "application/json"
        },
        "cache": {
          "name": "search-cache",
          "key": "search-{id}-{accountId}"
        }
      }
    },
    {
      "name": "extract-xpath",
      "type": "dataextraction",
      "dataExtraction": {
        "type": "XPATH",
        "threadCount": 8,
        "config": "classpath:my-operation-xpaths.json"
      }
    },
    {
      "name": "extract-json-inline",
      "type": "dataextraction",
      "dataExtraction": {
        "type": "JSON",
        "jsonataTransform": "{ 'status': status, 'value': data.value }"
      }
    },
    {
      "name": "extract-json-file",
      "type": "dataextraction",
      "dataExtraction": {
        "type": "JSONATA",
        "jsonataTransform": "classpath:transforms/my-operation.jsonata"
      }
    },
    {
      "name": "extract-jsonpath",
      "type": "dataextraction",
      "dataExtraction": {
        "type": "JSONPATH",
        "config": "classpath:my-operation-jsonpaths.json"
      }
    }
  ],

  "http": {
    "url": "http://api.example.com/items/{id}",
    "method": "GET",
    "contentType": "text/plain",
    "bodyTemplate": "{id}",
    "threadCount": 5,
    "timeoutMs": 3000,
    "header": {
      "Accept": "application/json"
    },
    "cache": {
      "name": "legacy-cache",
      "key": "legacy-{id}"
    }
  },

  "xpath": {
    "threadCount": 4,
    "config": "classpath:xpaths.json"
  },

  "dataExtraction": {
    "type": "XPATH",
    "config": "classpath:xpaths.json",
    "threadCount": 4,
    "jsonataTransform": ""
  },

  "enricher": {
    "type": "post",
    "enhancer": "classpath:enricher/my-operation-enricher.json"
  },

  "alias": [
    {
      "name": "FILE_SMALL",
      "request": {
        "inputSource": "FILE",
        "inputFilePath": "C:/work/data/my-operation.txt",
        "inputCount": 10
      }
    },
    {
      "name": "FILE_FILTERED",
      "request": {
        "inputSource": "FILE",
        "inputFilePath": "C:/work/data/my-operation.txt",
        "filterInput": [
          { "column": "id", "value": "12345", "operation": "eq" }
        ],
        "filterOutput": [
          { "column": "status", "value": "ACT.*", "operation": "like" }
        ]
      }
    },
    {
      "name": "ASYNC_ALL",
      "request": {
        "inputSource": "FILE",
        "inputFilePath": "C:/work/data/my-operation.txt",
        "executionMode": "ASYNC",
        "httpThreadCount": 20,
        "httpTimeoutMs": 10000
      }
    },
    {
      "name": "HTTP_INPUT",
      "request": {
        "inputSource": "HTTPCONFIG",
        "inputHttpUrl": "http://api.example.com/input-ids",
        "inputCount": 50
      }
    },
    {
      "name": "IDS_REQUEST",
      "request": {
        "inputSource": "REQUEST",
        "ids": ["id1", "id2", "id3"]
      }
    },
    {
      "name": "FILE_OUTPUT",
      "request": {
        "inputSource": "FILE",
        "inputFilePath": "C:/work/data/my-operation.txt",
        "outputData": "FILE",
        "outputFilePath": "C:/work/output/results.psv"
      }
    },
    {
      "name": "DEBUG",
      "request": {
        "inputSource": "FILE",
        "inputFilePath": "C:/work/data/my-operation.txt",
        "inputCount": 5,
        "debugMode": -1
      }
    },
    {
      "name": "DEBUG_META",
      "request": {
        "inputSource": "FILE",
        "inputFilePath": "C:/work/data/my-operation.txt",
        "inputCount": 5,
        "debugMode": 1
      }
    }
  ],

  "responseProcessor": [
    {
      "name": "convert-xml",
      "responseProcessor": {
        "type": "XML2JSON"
      }
    },
    {
      "name": "transform-jsonata",
      "responseProcessor": {
        "type": "JSONATA",
        "jsonataTransform": "classpath:transforms/my-transform.jsonata"
      }
    },
    {
      "name": "transform-jsonata-inline",
      "responseProcessor": {
        "type": "JSONATA",
        "jsonataTransform": "$[status = 'ACTIVE']"
      }
    }
  ]
}
