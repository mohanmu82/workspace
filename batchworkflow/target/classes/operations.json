[
  {
    "name": "pubmed",
    "activity": [
      {
        "name": "httpgetpubmeddata",
        "properties": {
          "application": "ICE",
          "dataEnvironment": "PRD"
        },	        
        "type": "HTTP",
        "http": {
          "url": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi?db=pubmed&id={id}&retmode=xml",
          "method": "GET",
          "threadCount": 5,
          "timeoutMs": 3000,
          "cache": {
            "name": "pubmeddata"
            ,"key" : "pubmed{id}"
          }          
        }
      },
      {
        "name": "extractxmlpubmed",
        "type": "dataextraction",
        "dataExtraction": {
          "type": "XPATH",
          "threadCount": 10,
          "config": "classpath:pubmed_xpaths.json"
        }
      }
    ],
    "mandatoryAttributes": "id",
    "enricher": {
      "type": "post",
      "enhancer": "classpath:enricher/pubmedbasic_enricher.json"
    },
    "alias": [
      {
        "name": "TECH",
        "request": {
          "inputSource": "FILE",
          "inputFilePath": "C:/work/data/pubmed.txt",
          "inputCount": 10,
          "filterInput": [
            { "column": "id", "value": "11748935", "operation": "eq" }
          ]
        }
      },
      {
        "name": "ASYNC_ALL",
        "request": {
          "inputSource": "FILE",
          "inputFilePath": "C:/work/data/pubmed.txt",
          "executionMode": "ASYNC",
          "httpThreadCount": 10,
          "httpTimeoutMs": 5000
        }
      }
    ],
    "responseProcessor": [
      {
        "name": "attribute12",
        "responseProcessor": {
          "type": "attribute",
          "name": "attribute12"
        }
      },
      {
        "name": "status",
        "responseProcessor": {
          "type": "aggregation",
          "name": "status"
        }
      }
    ]	    
  },
  {
    "name": "zip",
    "activity": [
      {
        "name": "httpgetzipdata",
        "type": "HTTP",
        "http": {
          "url": "https://api.zippopotam.us/us/{id}",
          "method": "GET",
          "threadCount": 5,
          "timeoutMs": 3000,
          "header": {
            "Accept": "application/json",
            "X-Api-Key": "abc123",
            "X-Correlation-Id": "batch-runner"
          }
        }
      },
      {
        "name": "extractjsonzip",
        "type": "dataextraction",
        "dataExtraction": {
          "type": "JSON",
          "jsonataTransform": "classpath:transforms/zip.jsonata"
        }
      }
    ]
  }
]
